<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="using:GymForge.Desktop.Converters">

    <!-- Converters -->
    <conv:SidebarWidthConverter x:Key="SidebarWidthConverter" />
    <conv:CollapsedIconConverter x:Key="CollapsedIconConverter" />
    <conv:StatusColorConverter x:Key="StatusColorConverter" />

    <!-- Sidebar & Topbar colors (Light) -->
    <SolidColorBrush x:Key="SidebarBackground" Color="#F7F7F8" />
    <SolidColorBrush x:Key="TopbarBackground" Color="#FFFFFF" />

</ResourceDictionary>
