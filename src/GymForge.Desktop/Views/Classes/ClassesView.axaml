<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Classes"
             x:Class="GymForge.Desktop.Views.Classes.ClassesView"
             x:DataType="vm:ClassesViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <Border Grid.Row="0" Classes="Toolbar">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Calendar}" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="Clases" Classes="ToolbarTitle" />
                    <Border Classes="CountBadge">
                        <TextBlock Text="{Binding Classes.Count}" />
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding LoadCommand}" Classes="Ghost" ToolTip.Tip="Actualizar">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Refresh}" FontSize="16" />
                    </Button>
                    <Button Command="{Binding OpenFormCommand}" Classes="Primary">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="16" />
                            <TextBlock Text="Nueva clase" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Formulario -->
        <Border Grid.Row="1" Classes="Toolbar" IsVisible="{Binding IsFormOpen}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre *" Classes="FormLabel" />
                        <TextBox Text="{Binding Name}" Watermark="Ej: Funcional" Width="240" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Duración (min)" Classes="FormLabel" />
                        <NumericUpDown Value="{Binding DurationMin}" Minimum="10" Maximum="240" Increment="15" Width="130" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Cupo" Classes="FormLabel" />
                        <NumericUpDown Value="{Binding Capacity}" Minimum="1" Increment="5" Width="120" />
                    </StackPanel>
                </StackPanel>
                <fa:InfoBar IsOpen="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Severity="Error" Title="Error" Message="{Binding ErrorMessage}" IsClosable="False" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Crear clase" Command="{Binding CreateCommand}" Classes="Primary" />
                    <Button Content="Cancelar" Command="{Binding CancelFormCommand}" Classes="Ghost" />
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Classes}"
                  IsReadOnly="True" AutoGenerateColumns="False" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Clase" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Duración" Binding="{Binding DurationMin, StringFormat={}{0} min}" Width="140" />
                <DataGridTextColumn Header="Cupo" Binding="{Binding Capacity, StringFormat={}{0} personas}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Classes="EmptyState" IsVisible="{Binding IsEmpty}">
            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Calendar}" />
            <TextBlock Classes="EmptyTitle" Text="Todavía no hay clases" />
            <TextBlock Classes="EmptyBody"
                       Text="Creá la primera con «Nueva clase». Los horarios y reservas llegan después." />
        </StackPanel>

    </Grid>

</UserControl>
