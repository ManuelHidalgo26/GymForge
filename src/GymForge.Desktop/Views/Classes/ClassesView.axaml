<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Classes"
             x:Class="GymForge.Desktop.Views.Classes.ClassesView"
             x:DataType="vm:ClassesViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <Border Grid.Row="0" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Calendar}" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="Clases" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border CornerRadius="12" Padding="8,2"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                        <TextBlock Text="{Binding Classes.Count}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding LoadCommand}" Classes="NavButton" ToolTip.Tip="Actualizar">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Refresh}" FontSize="16" />
                    </Button>
                    <Button Command="{Binding OpenFormCommand}" Classes="NavButton"
                            Background="{DynamicResource SystemAccentColor}" Foreground="White">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="16" />
                            <TextBlock Text="Nueva clase" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Formulario -->
        <Border Grid.Row="1" Padding="16,12" IsVisible="{Binding IsFormOpen}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre *" FontSize="12" Opacity="0.7" />
                        <TextBox Text="{Binding Name}" Watermark="Ej: Funcional" Width="240" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Duración (min)" FontSize="12" Opacity="0.7" />
                        <NumericUpDown Value="{Binding DurationMin}" Minimum="10" Maximum="240" Increment="15" Width="130" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Cupo" FontSize="12" Opacity="0.7" />
                        <NumericUpDown Value="{Binding Capacity}" Minimum="1" Increment="5" Width="120" />
                    </StackPanel>
                </StackPanel>
                <fa:InfoBar IsOpen="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Severity="Error" Title="Error" Message="{Binding ErrorMessage}" IsClosable="False" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Crear clase" Command="{Binding CreateCommand}" Classes="NavButton"
                            Background="{DynamicResource SystemAccentColor}" Foreground="White" />
                    <Button Content="Cancelar" Command="{Binding CancelFormCommand}" Classes="NavButton" />
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Classes}"
                  IsReadOnly="True" AutoGenerateColumns="False" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Clase" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Duración" Binding="{Binding DurationMin, StringFormat={}{0} min}" Width="140" />
                <DataGridTextColumn Header="Cupo" Binding="{Binding Capacity, StringFormat={}{0} personas}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Spacing="10"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding IsEmpty}">
            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Calendar}" FontSize="44" Opacity="0.25"
                           HorizontalAlignment="Center" />
            <TextBlock Text="Todavía no hay clases" FontSize="15" FontWeight="SemiBold" Opacity="0.7"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Creá la primera con «Nueva clase». Los horarios y reservas llegan después."
                       FontSize="12" Opacity="0.5" HorizontalAlignment="Center" />
        </StackPanel>

    </Grid>

</UserControl>
