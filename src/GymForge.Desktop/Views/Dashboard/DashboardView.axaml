<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Dashboard"
             x:Class="GymForge.Desktop.Views.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Styles>
        <!-- Etiqueta de vencimiento -->
        <Style Selector="TextBlock.when">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.when.urgent">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28,22" Spacing="16" MaxWidth="1240">

            <!-- ── Header: título + fecha | acciones rápidas ──────────────── -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <StackPanel Spacing="3">
                    <TextBlock Text="Dashboard" Classes="PageTitle" />
                    <TextBlock Text="{Binding TodayLabel}" Classes="PageSubtitle" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="Primary" Command="{Binding QuickCreateMemberCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="15" />
                            <TextBlock Text="Nuevo socio" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Classes="Secondary" Command="{Binding QuickCheckInCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Permissions}" FontSize="15" />
                            <TextBlock Text="Check-in" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <Button Classes="Secondary" Command="{Binding QuickChargeCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="15" />
                            <TextBlock Text="Cobrar" FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── KPIs ───────────────────────────────────────────────────── -->
            <Grid ColumnDefinitions="*,*,*,*">
                <Grid.Styles>
                    <Style Selector="Grid > Border.Card">
                        <Setter Property="Margin" Value="0,0,14,0" />
                    </Style>
                    <Style Selector="Grid > Border.Card:nth-last-child(1)">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </Grid.Styles>

                <!-- Socios activos -->
                <Border Grid.Column="0" Classes="Card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Classes="IconChip">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.People}" FontSize="18"
                                               Foreground="{DynamicResource SystemAccentColor}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Socios activos" FontSize="13"
                                       Margin="11,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding TotalActiveMembers}" FontSize="30" FontWeight="Bold" Classes="Numeric" />
                        <TextBlock Text="{Binding MembersSubtitle}" Classes="Caption" />
                    </StackPanel>
                </Border>

                <!-- Check-ins -->
                <Border Grid.Column="1" Classes="Card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Classes="IconChip" Background="{DynamicResource SuccessTintBrush}">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Permissions}" FontSize="18"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Check-ins hoy" FontSize="13"
                                       Margin="11,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding CheckInsToday}" FontSize="30" FontWeight="Bold" Classes="Numeric" />
                        <TextBlock Text="{Binding CheckInsSubtitle}" Classes="Caption" />
                    </StackPanel>
                </Border>

                <!-- En mora -->
                <Border Grid.Column="2" Classes="Card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Classes="IconChip" Background="{DynamicResource WarningTintBrush}">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Alert}" FontSize="18"
                                               Foreground="{DynamicResource WarningBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="En mora" FontSize="13"
                                       Margin="11,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="{Binding OverdueMembers}" FontSize="30" FontWeight="Bold" Classes="Numeric" />
                        <TextBlock Text="{Binding OverdueSubtitle}" Classes="Caption" />
                    </StackPanel>
                </Border>

                <!-- Recaudación -->
                <Border Grid.Column="3" Classes="Card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Classes="IconChip" Background="{DynamicResource SuccessTintBrush}">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="18"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="Recaudación del mes" FontSize="13"
                                       Margin="11,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <TextBlock FontSize="30" FontWeight="Bold" Classes="Numeric">
                            <Run Text="$" /><Run Text="{Binding RevenueThisMonth, StringFormat={}{0:N0}}" />
                        </TextBlock>
                        <Border CornerRadius="99" Padding="8,2" HorizontalAlignment="Left"
                                IsVisible="{Binding HasRevenueTrend}"
                                Background="{Binding RevenueTrendUp, Converter={StaticResource ActiveColorBrushConverter}, ConverterParameter=tint}">
                            <TextBlock Text="{Binding RevenueTrendText}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding RevenueTrendUp, Converter={StaticResource ActiveColorBrushConverter}}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Gráfico + listas ───────────────────────────────────────── -->
            <Grid ColumnDefinitions="7*,5*">

                <!-- Recaudación últimos 30 días -->
                <Border Grid.Column="0" Classes="Card" Margin="0,0,14,0" VerticalAlignment="Top">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Recaudación" Classes="SectionTitle" />
                                <TextBlock Text="Últimos 30 días" FontSize="11.5"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Revenue30DaysTotal}" FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Right" Classes="Numeric" />
                                <TextBlock Text="total del período" FontSize="10.5" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <!-- Área + línea de recaudación (el Viewbox estira el sistema
                             virtual 300×130 al ancho de la card); barras transparentes
                             encima para los tooltips por día. -->
                        <Grid Height="130">
                            <Viewbox Stretch="Fill">
                                <Canvas Width="300" Height="130">
                                    <Path Data="{Binding RevenueAreaGeometry}"
                                          Fill="{DynamicResource SystemAccentColor}" Opacity="0.95">
                                        <Path.OpacityMask>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                <GradientStop Color="#59FFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Path.OpacityMask>
                                    </Path>
                                    <Path Data="{Binding RevenueLineGeometry}"
                                          Stroke="{DynamicResource SystemAccentColor}"
                                          StrokeThickness="1.5"
                                          StrokeLineCap="Round" StrokeJoin="Round" />
                                </Canvas>
                            </Viewbox>

                            <ItemsControl ItemsSource="{Binding RevenueBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" Columns="30" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RevenueBarVm">
                                        <Grid ToolTip.Tip="{Binding Tooltip}" Background="Transparent" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding ChartFromLabel}" FontSize="10.5"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding ChartToLabel}" FontSize="10.5"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Columna derecha: vencimientos + actividad -->
                <StackPanel Grid.Column="1" Spacing="14">

                    <!-- Vencen esta semana -->
                    <Border Classes="Card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Vencen esta semana" Classes="SectionTitle" />
                            <TextBlock Text="Sin vencimientos en los próximos 7 días 🎉" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       IsVisible="{Binding HasNoExpiring}" />
                            <ItemsControl ItemsSource="{Binding ExpiringRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ExpiringRowVm">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4">
                                            <Border Classes="Avatar">
                                                <TextBlock Text="{Binding Initials}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding MemberName}" FontSize="12.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding PlanName}" FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Classes="when" Classes.urgent="{Binding IsUrgent}"
                                                       Text="{Binding WhenLabel}" FontSize="11.5" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Actividad de hoy -->
                    <Border Classes="Card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Actividad de hoy" Classes="SectionTitle" />
                            <TextBlock Text="Todavía no hubo accesos hoy" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       IsVisible="{Binding HasNoAccess}" />
                            <ItemsControl ItemsSource="{Binding AccessRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AccessRowVm">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,4">
                                            <Border Classes="Avatar">
                                                <TextBlock Text="{Binding Initials}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,8,0" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding MemberName}" FontSize="12.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                                           Foreground="{Binding Granted, Converter={StaticResource ActiveColorBrushConverter}}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding TimeLabel}" FontSize="11.5"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>
