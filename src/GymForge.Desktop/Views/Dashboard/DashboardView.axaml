<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Dashboard"
             x:Class="GymForge.Desktop.Views.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Border.KpiCard">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="BoxShadow" Value="0 1 4 0 #14000000" />
        </Style>
        <!-- Botón de acción rápida: alto/icono+texto verticales (NavButton fija Height=40 y corta el texto) -->
        <Style Selector="Button.QuickAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Width" Value="150" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.QuickAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="28,24" Spacing="24">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Dashboard" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Resumen del día" FontSize="13" Opacity="0.6" />
            </StackPanel>

            <!-- KPI row -->
            <Grid ColumnDefinitions="*,*,*,*" HorizontalAlignment="Stretch">
                <Grid.Styles>
                    <Style Selector="Grid > Border">
                        <Setter Property="Margin" Value="0,0,12,0" />
                    </Style>
                    <Style Selector="Grid > Border:nth-last-child(1)">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </Grid.Styles>

                <!-- Total Socios Activos -->
                <Border Grid.Column="0" Classes="KpiCard">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.People}" FontSize="20"
                                           Foreground="{DynamicResource SystemAccentColor}" />
                            <TextBlock Text="Socios activos" FontSize="13" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding TotalActiveMembers}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Membresías vigentes" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Check-ins hoy -->
                <Border Grid.Column="1" Classes="KpiCard">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Permissions}" FontSize="20"
                                           Foreground="{DynamicResource SystemAccentColorLight1}" />
                            <TextBlock Text="Check-ins hoy" FontSize="13" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding CheckInsToday}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Accesos del día" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Socios en mora -->
                <Border Grid.Column="2" Classes="KpiCard">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Alert}" FontSize="20"
                                           Foreground="#E85F00" />
                            <TextBlock Text="En mora" FontSize="13" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock Text="{Binding OverdueMembers}"
                                   FontSize="32" FontWeight="Bold" />
                        <TextBlock Text="Requieren cobro" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Recaudación del mes -->
                <Border Grid.Column="3" Classes="KpiCard" Margin="0">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="20"
                                           Foreground="#2E7D32" />
                            <TextBlock Text="Recaudación" FontSize="13" Opacity="0.7" />
                        </StackPanel>
                        <TextBlock FontSize="32" FontWeight="Bold">
                            <Run Text="$" /><Run Text="{Binding RevenueThisMonth, StringFormat={}{0:N0}}" />
                        </TextBlock>
                        <TextBlock Text="Este mes" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick actions -->
            <Border Classes="KpiCard">
                <StackPanel Spacing="12">
                    <TextBlock Text="Acciones rápidas" FontSize="14" FontWeight="SemiBold" />
                    <WrapPanel Orientation="Horizontal">
                        <Button Classes="QuickAction" Margin="0,0,10,0"
                                Command="{Binding QuickCreateMemberCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="24"
                                               HorizontalAlignment="Center" />
                                <TextBlock Text="Nuevo socio" FontSize="12" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="QuickAction" Margin="0,0,10,0"
                                Command="{Binding QuickCheckInCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Permissions}" FontSize="24"
                                               HorizontalAlignment="Center" />
                                <TextBlock Text="Check-in manual" FontSize="12" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="QuickAction"
                                Command="{Binding QuickChargeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="24"
                                               HorizontalAlignment="Center" />
                                <TextBlock Text="Registrar cobro" FontSize="12" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
