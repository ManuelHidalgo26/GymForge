<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Members"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:domain="using:GymForge.Domain.Enums"
             x:Class="GymForge.Desktop.Views.Members.MembersListView"
             x:DataType="vm:MembersListViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- Search -->
                    <TextBox Width="320"
                             Watermark="Buscar socio (nombre, DNI, email)..."
                             Text="{Binding SearchText}">
                        <TextBox.InnerLeftContent>
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Find}" FontSize="14"
                                           Margin="8,0,4,0" Opacity="0.5" />
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <!-- Status filter -->
                    <ComboBox Width="160"
                              SelectedValue="{Binding StatusFilter}"
                              SelectedValueBinding="{ReflectionBinding Tag}"
                              PlaceholderText="Todos los estados">
                        <ComboBoxItem Content="Activos"    Tag="{x:Static domain:MemberStatus.Active}" />
                        <ComboBoxItem Content="Vencidos"   Tag="{x:Static domain:MemberStatus.Expired}" />
                        <ComboBoxItem Content="Morosos"    Tag="{x:Static domain:MemberStatus.Overdue}" />
                        <ComboBoxItem Content="Congelados" Tag="{x:Static domain:MemberStatus.Frozen}" />
                        <ComboBoxItem Content="Cancelados" Tag="{x:Static domain:MemberStatus.Cancelled}" />
                    </ComboBox>

                    <Button Content="Limpiar"
                            Command="{Binding ClearSearchCommand}"
                            Classes="NavButton" />
                </StackPanel>

                <!-- Right: refresh + nuevo socio -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding LoadCommand}"
                            Classes="NavButton"
                            ToolTip.Tip="Actualizar">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Refresh}" FontSize="16" />
                    </Button>
                    <Button Command="{Binding CreateMemberCommand}"
                            Classes="NavButton">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="16" />
                            <TextBlock Text="Nuevo socio" />
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── DataGrid ───────────────────────────────────────────────────── -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Members}"
                  SelectedItem="{Binding SelectedMember}"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  AutoGenerateColumns="False"
                  DoubleTapped="DataGrid_DoubleTapped">

            <DataGrid.Columns>

                <!-- Avatar -->
                <DataGridTemplateColumn Header="" Width="44" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="28" Height="28" CornerRadius="14"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Margin="6,0">
                                <TextBlock Text="{Binding FirstName[0]}"
                                           Foreground="White" FontWeight="SemiBold" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Apellido"
                                    Binding="{Binding LastName}" Width="160" />
                <DataGridTextColumn Header="Nombre"
                                    Binding="{Binding FirstName}" Width="140" />
                <DataGridTextColumn Header="DNI/Doc"
                                    Binding="{Binding DocumentNumber}" Width="110" />
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}" Width="*" />
                <DataGridTextColumn Header="Teléfono"
                                    Binding="{Binding Mobile}" Width="155" />

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Estado" Width="110"
                                        SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,2" Margin="4,0"
                                    HorizontalAlignment="Left">
                                <Border.Background>
                                    <SolidColorBrush
                                        Color="{Binding Status,
                                            Converter={StaticResource StatusColorConverter}}"
                                        Opacity="0.15" />
                                </Border.Background>
                                <TextBlock Text="{Binding Status, Converter={StaticResource EnumEs}}"
                                           FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush
                                            Color="{Binding Status,
                                                Converter={StaticResource StatusColorConverter}}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Ingreso"
                                    Binding="{Binding JoinDate}" Width="100" />
                <DataGridTextColumn Header="Edad"
                                    Binding="{Binding Age}" Width="75" />

                <!-- Row actions -->
                <DataGridTemplateColumn Header="" Width="80" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:MembersListViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0">
                                <Button Classes="IconButton" ToolTip.Tip="Ver ficha"
                                        CommandParameter="{Binding}"
                                        Command="{Binding $parent[UserControl].((vm:MembersListViewModel)DataContext).OpenDetailCommand}">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.ChevronRight}" FontSize="16" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Footer / Paginación ────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="16,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <fa:ProgressRing IsVisible="{Binding IsLoading}"
                                     Width="18" Height="18" />
                    <TextBlock FontSize="12" Opacity="0.7"
                               Text="{Binding TotalCount, StringFormat={}{0} socio(s)}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Command="{Binding PreviousPageCommand}" Classes="NavButton"
                            IsEnabled="{Binding CurrentPage, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.ChevronLeft}" FontSize="14" />
                    </Button>
                    <TextBlock VerticalAlignment="Center" FontSize="12">
                        <Run Text="Pág. " />
                        <Run Text="{Binding CurrentPage}" FontWeight="SemiBold" />
                        <Run Text=" / " />
                        <Run Text="{Binding TotalPages}" />
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" Classes="NavButton">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.ChevronRight}" FontSize="14" />
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
