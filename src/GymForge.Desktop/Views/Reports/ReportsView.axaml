<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Reports"
             xmlns:rep="using:GymForge.Application.UseCases.Reports"
             x:Class="GymForge.Desktop.Views.Reports.ReportsView"
             x:DataType="vm:ReportsViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Toolbar: rango de fechas ───────────────────────────────────── -->
        <Border Grid.Row="0" Classes="Toolbar">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="10">
                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Document}" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="Reportes" Classes="ToolbarTitle" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <TextBlock Text="Desde" Classes="FormLabel" VerticalAlignment="Center" />
                    <DatePicker SelectedDate="{Binding From, Converter={StaticResource DateOnlyOffset}}" />
                    <TextBlock Text="Hasta" Classes="FormLabel" VerticalAlignment="Center" />
                    <DatePicker SelectedDate="{Binding To, Converter={StaticResource DateOnlyOffset}}" />
                    <Button Content="Hoy" Command="{Binding TodayCommand}" Classes="Ghost" />
                    <Button Content="Este mes" Command="{Binding ThisMonthCommand}" Classes="Ghost" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── KPIs del período ───────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="16,12" ColumnSpacing="12">
            <Border Grid.Column="0" Classes="Card">
                <StackPanel Spacing="2">
                    <TextBlock Text="Recaudación del período" Classes="FormLabel" />
                    <TextBlock Text="{Binding Total, StringFormat={}{0:C}}" FontSize="24" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="Card">
                <StackPanel Spacing="2">
                    <TextBlock Text="Pagos registrados" Classes="FormLabel" />
                    <TextBlock Text="{Binding Count}" FontSize="24" FontWeight="Bold" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Tabla de pagos ─────────────────────────────────────────────── -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  IsReadOnly="True" AutoGenerateColumns="False" CanUserSortColumns="True"
                  Margin="16,0,16,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha"
                                    Binding="{Binding ReceivedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                    Width="160" />
                <DataGridTextColumn Header="Socio" Binding="{Binding MemberName}" Width="*" />
                <DataGridTemplateColumn Header="Método" Width="170" SortMemberPath="Method">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="rep:ReportPaymentRow">
                            <TextBlock Text="{Binding Method, Converter={StaticResource EnumEs}}"
                                       VerticalAlignment="Center" Margin="8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Monto"
                                    Binding="{Binding Amount, StringFormat={}{0:C}}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Estado vacío ───────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Classes="EmptyState" IsVisible="{Binding IsEmpty}">
            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Document}" />
            <TextBlock Classes="EmptyTitle" Text="Sin pagos en el período" />
            <TextBlock Classes="EmptyBody" Text="Ajustá el rango de fechas o registrá cobros desde Caja." />
        </StackPanel>

    </Grid>

</UserControl>
