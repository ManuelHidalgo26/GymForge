<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Routines"
             xmlns:ex="using:GymForge.Application.UseCases.Exercises"
             xmlns:enums="using:GymForge.Domain.Enums"
             x:Class="GymForge.Desktop.Views.Routines.ExerciseLibraryView"
             x:DataType="vm:ExerciseLibraryViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <Border Grid.Row="0" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Globe}" FontSize="20" VerticalAlignment="Center" />
                    <TextBlock Text="Biblioteca de ejercicios" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Border CornerRadius="12" Padding="8,2"
                            Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                        <TextBlock Text="{Binding Exercises.Count}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <TextBox Width="240" Watermark="Buscar ejercicio..."
                             Text="{Binding SearchText}" />
                    <ComboBox Width="170" PlaceholderText="Grupo muscular"
                              ItemsSource="{Binding MuscleGroups}"
                              SelectedItem="{Binding MuscleFilter}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="enums:MuscleGroup">
                                <TextBlock Text="{Binding Converter={StaticResource EnumEs}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Limpiar" Command="{Binding ClearFiltersCommand}" Classes="NavButton" />
                    <Button Command="{Binding OpenCreateFormCommand}" Classes="NavButton"
                            Background="{DynamicResource SystemAccentColor}" Foreground="White">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="16" />
                            <TextBlock Text="Nuevo ejercicio" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Formulario alta / edición ──────────────────────────────────── -->
        <Border Grid.Row="1" Padding="16,12" IsVisible="{Binding IsFormOpen}"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding FormTitle}" FontSize="13" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Nombre *" FontSize="12" Opacity="0.7" />
                        <TextBox Text="{Binding Name}" Watermark="Ej: Press inclinado" Width="220" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Grupo muscular" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding MuscleGroups}" SelectedItem="{Binding Muscle}" Width="150">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="enums:MuscleGroup">
                                    <TextBlock Text="{Binding Converter={StaticResource EnumEs}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Equipo" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding EquipmentOptions}" SelectedItem="{Binding Equipment}" Width="140">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="enums:Equipment">
                                    <TextBlock Text="{Binding Converter={StaticResource EnumEs}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Tipo" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding MovementOptions}" SelectedItem="{Binding Movement}" Width="130">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="enums:MovementType">
                                    <TextBlock Text="{Binding Converter={StaticResource EnumEs}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Dificultad (1-5)" FontSize="12" Opacity="0.7" />
                        <NumericUpDown Value="{Binding Difficulty}" Minimum="1" Maximum="5" Increment="1" Width="110" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Guardar" Command="{Binding SaveCommand}" Classes="NavButton"
                            Background="{DynamicResource SystemAccentColor}" Foreground="White" />
                    <Button Content="Cancelar" Command="{Binding CancelFormCommand}" Classes="NavButton" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Error (p.ej. al eliminar uno usado en rutinas) ─────────────── -->
        <fa:InfoBar Grid.Row="2" Margin="16,8,16,0"
                    IsOpen="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Severity="Warning" Title="Atención"
                    Message="{Binding ErrorMessage}" IsClosable="False" />

        <DataGrid Grid.Row="3" ItemsSource="{Binding Exercises}"
                  IsReadOnly="True" AutoGenerateColumns="False" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ejercicio" Binding="{Binding Name}" Width="*" />
                <DataGridTemplateColumn Header="Grupo muscular" Width="160" SortMemberPath="Muscle">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="ex:ExerciseDto">
                            <TextBlock Text="{Binding Muscle, Converter={StaticResource EnumEs}}"
                                       VerticalAlignment="Center" Margin="8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Equipo" Width="140" SortMemberPath="Equipment">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="ex:ExerciseDto">
                            <TextBlock Text="{Binding Equipment, Converter={StaticResource EnumEs}}"
                                       VerticalAlignment="Center" Margin="8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Tipo" Width="120" SortMemberPath="Movement">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="ex:ExerciseDto">
                            <TextBlock Text="{Binding Movement, Converter={StaticResource EnumEs}}"
                                       VerticalAlignment="Center" Margin="8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Dificultad" Binding="{Binding Difficulty, StringFormat={}{0}/5}" Width="100" />
                <DataGridTemplateColumn Header="" Width="100" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="ex:ExerciseDto">
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0">
                                <Button Classes="IconButton" ToolTip.Tip="Modificar"
                                        CommandParameter="{Binding}"
                                        Command="{Binding $parent[UserControl].((vm:ExerciseLibraryViewModel)DataContext).EditExerciseCommand}">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Edit}" FontSize="14" />
                                </Button>
                                <Button Classes="IconButton" ToolTip.Tip="Eliminar">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Delete}" FontSize="14" Foreground="#C62828" />
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedRight">
                                            <StackPanel Spacing="8" Width="220">
                                                <TextBlock Text="¿Eliminar este ejercicio?" FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                                                           Text="No se puede eliminar si está usado en rutinas." />
                                                <Button Content="Eliminar definitivamente"
                                                        Background="#C62828" Foreground="White"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Center"
                                                        CommandParameter="{Binding}"
                                                        Command="{Binding $parent[UserControl].((vm:ExerciseLibraryViewModel)DataContext).DeleteExerciseCommand}" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Spacing="10"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding IsEmpty}">
            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Globe}" FontSize="44" Opacity="0.25"
                           HorizontalAlignment="Center" />
            <TextBlock Text="Sin ejercicios para esos filtros" FontSize="15" FontWeight="SemiBold" Opacity="0.7"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Probá con otra búsqueda u otro grupo muscular." FontSize="12" Opacity="0.5"
                       HorizontalAlignment="Center" />
        </StackPanel>

    </Grid>

</UserControl>
