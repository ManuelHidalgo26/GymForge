<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Settings"
             xmlns:set="using:GymForge.Application.UseCases.Settings"
             x:Class="GymForge.Desktop.Views.Settings.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="16,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Settings}" FontSize="20" VerticalAlignment="Center" />
                <TextBlock Text="Configuración" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Center">

                <!-- ── Datos del gimnasio ─────────────────────────────────── -->
                <Border CornerRadius="12" Padding="24"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Datos del gimnasio" FontSize="15" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Nombre / Razón social *" FontSize="12" Opacity="0.7" />
                                <TextBox Text="{Binding LegalName}" Width="320" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="CUIT *" FontSize="12" Opacity="0.7" />
                                <TextBox Text="{Binding TaxId}" Watermark="30-12345678-9" Width="180" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding CompanyMessage}" FontSize="12"
                                   Foreground="{Binding CompanySaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding CompanyMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                        <Button Content="Guardar cambios" Command="{Binding SaveCompanyCommand}" Classes="NavButton"
                                Background="{DynamicResource SystemAccentColor}" Foreground="White"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- ── Sedes ──────────────────────────────────────────────── -->
                <Border CornerRadius="12" Padding="24"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Sedes" FontSize="15" FontWeight="SemiBold" />

                        <ItemsControl ItemsSource="{Binding Sites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="set:SiteDto">
                                    <Grid ColumnDefinitions="Auto,*" Margin="0,4">
                                        <fa:SymbolIcon Grid.Column="0" Symbol="{x:Static fa:Symbol.Home}"
                                                       FontSize="14" Margin="0,0,10,0" Opacity="0.6" />
                                        <TextBlock Grid.Column="1">
                                            <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                            <Run Text=" — " />
                                            <Run Text="{Binding Address}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />

                        <TextBlock Text="Agregar sede" FontSize="13" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding NewSiteName}" Watermark="Nombre (ej: Sede Sur)" Width="200" />
                            <TextBox Text="{Binding NewSiteAddress}" Watermark="Dirección" Width="260" />
                            <Button Command="{Binding AddSiteCommand}" Classes="NavButton">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Add}" FontSize="14" />
                                    <TextBlock Text="Agregar" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding SiteMessage}" FontSize="12" Foreground="#C62828"
                                   IsVisible="{Binding SiteMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ── Info del sistema ───────────────────────────────────── -->
                <Border CornerRadius="12" Padding="24"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Sistema" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock FontSize="12" Opacity="0.7"
                                   Text="Los datos se guardan localmente en esta PC (%LOCALAPPDATA%\GymForge). Moneda: ARS · Zona horaria: Argentina (UTC-3)."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
