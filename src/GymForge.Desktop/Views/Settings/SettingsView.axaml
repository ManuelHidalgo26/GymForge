<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Settings"
             xmlns:set="using:GymForge.Application.UseCases.Settings"
             x:Class="GymForge.Desktop.Views.Settings.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Classes="Toolbar">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Settings}" FontSize="20" VerticalAlignment="Center" />
                <TextBlock Text="Configuración" Classes="ToolbarTitle" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Center">

                <!-- ── Datos del gimnasio ─────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Datos del gimnasio" FontSize="15" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Nombre / Razón social *" Classes="FormLabel" />
                                <TextBox Text="{Binding LegalName}" Width="320" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="CUIT *" Classes="FormLabel" />
                                <TextBox Text="{Binding TaxId}" Watermark="30-12345678-9" Width="180" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding CompanyMessage}" FontSize="12"
                                   Foreground="{Binding CompanySaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding CompanyMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                        <Button Content="Guardar cambios" Command="{Binding SaveCompanyCommand}" Classes="Primary"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- ── Seguridad / PIN ────────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Seguridad — PIN de acceso" FontSize="15" FontWeight="SemiBold" />

                        <Border CornerRadius="8" Padding="12,8" Background="#33F59E0B"
                                IsVisible="{Binding IsDefaultPinInUse}">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource DangerBrush}"
                                       Text="⚠ Todavía está activo el PIN de fábrica (1234). Cambialo antes de poner el gimnasio en marcha." />
                        </Border>

                        <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                   Text="El PIN se usa para abrir caja e iniciar sesión de cajero. Tiene que tener entre 4 y 8 dígitos." />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="PIN actual" Classes="FormLabel" />
                                <TextBox Text="{Binding CurrentPin}" PasswordChar="●" MaxLength="8" Width="140" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Nuevo PIN" Classes="FormLabel" />
                                <TextBox Text="{Binding NewPin}" PasswordChar="●" MaxLength="8" Width="140" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Repetir nuevo PIN" Classes="FormLabel" />
                                <TextBox Text="{Binding NewPinConfirm}" PasswordChar="●" MaxLength="8" Width="140" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding PinMessage}" FontSize="12"
                                   Foreground="{Binding PinSaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding PinMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                        <Button Content="Cambiar PIN" Command="{Binding ChangePinCommand}" Classes="Primary"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- ── Marca ──────────────────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Marca" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                       Text="El logo aparece en el menú y en los recibos. El color de acento pinta botones, íconos y resaltados de toda la app." />
                        </StackPanel>

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Border Width="64" Height="64" CornerRadius="12" ClipToBounds="True"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1">
                                <Panel>
                                    <Image Source="{Binding LogoPreview}" Stretch="UniformToFill"
                                           IsVisible="{Binding HasLogoPreview}" />
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Image}" FontSize="26" Opacity="0.35"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsVisible="{Binding !HasLogoPreview}" />
                                </Panel>
                            </Border>
                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding PickLogoCommand}" Classes="Secondary">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Upload}" FontSize="14" />
                                            <TextBlock Text="Elegir logo" />
                                        </StackPanel>
                                    </Button>
                                    <Button Content="Quitar" Classes="Ghost"
                                            Command="{Binding RemoveLogoCommand}"
                                            IsVisible="{Binding HasLogoPreview}" />
                                </StackPanel>
                                <TextBlock Text="PNG o JPG, preferentemente cuadrado." Classes="Caption" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Color de acento -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Color de acento" Classes="FormLabel" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="Swatch" Background="#6366F1" ToolTip.Tip="Indigo"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#6366F1"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#6366F1}" />
                                <Button Classes="Swatch" Background="#2563EB" ToolTip.Tip="Azul"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#2563EB"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#2563EB}" />
                                <Button Classes="Swatch" Background="#059669" ToolTip.Tip="Esmeralda"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#059669"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#059669}" />
                                <Button Classes="Swatch" Background="#7C3AED" ToolTip.Tip="Violeta"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#7C3AED"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#7C3AED}" />
                                <Button Classes="Swatch" Background="#D97706" ToolTip.Tip="Ámbar"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#D97706"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#D97706}" />
                                <Button Classes="Swatch" Background="#DC2626" ToolTip.Tip="Granate"
                                        Command="{Binding SelectAccentCommand}" CommandParameter="#DC2626"
                                        Classes.selected="{Binding BrandColorHex, Converter={StaticResource StringEquals}, ConverterParameter=#DC2626}" />
                                <TextBox Text="{Binding BrandColorHex}" Watermark="#6366F1" Width="110"
                                         VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding BrandMessage}" FontSize="12"
                                   Foreground="{Binding BrandSaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding BrandMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                        <Button Content="Guardar marca" Command="{Binding SaveBrandingCommand}" Classes="Primary"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- ── Sedes ──────────────────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Sedes" FontSize="15" FontWeight="SemiBold" />

                        <ItemsControl ItemsSource="{Binding Sites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="set:SiteDto">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                        <fa:SymbolIcon Grid.Column="0" Symbol="{x:Static fa:Symbol.Home}"
                                                       FontSize="14" Margin="0,0,10,0" Opacity="0.6" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                            <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                            <Run Text=" — " />
                                            <Run Text="{Binding Address}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </TextBlock>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                                            <Button Classes="IconButton" ToolTip.Tip="Modificar sede"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).EditSiteCommand}">
                                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Edit}" FontSize="13" />
                                            </Button>
                                            <Button Classes="IconButton" ToolTip.Tip="Eliminar sede">
                                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Delete}" FontSize="13"
                                                               Foreground="{DynamicResource DangerBrush}" />
                                                <Button.Flyout>
                                                    <Flyout Placement="BottomEdgeAlignedRight">
                                                        <StackPanel Spacing="8" Width="240">
                                                            <TextBlock Text="¿Eliminar esta sede?" FontWeight="SemiBold" FontSize="13" />
                                                            <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                                                                       Text="Si tiene socios o movimientos se desactiva (conserva el historial). No se puede eliminar la única sede." />
                                                            <Button Content="Eliminar"
                                                                    Classes="Danger"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Center"
                                                                    CommandParameter="{Binding}"
                                                                    Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteSiteCommand}" />
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />

                        <TextBlock Text="{Binding SiteFormTitle}" FontSize="13" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding NewSiteName}" Watermark="Nombre (ej: Sede Sur)" Width="170" />
                            <TextBox Text="{Binding NewSiteAddress}" Watermark="Dirección" Width="220" />
                            <TextBox Text="{Binding NewSitePhone}" Watermark="Teléfono (opcional)" Width="150" />
                            <Button Command="{Binding SaveSiteCommand}" Classes="Secondary">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Save}" FontSize="14" />
                                    <TextBlock Text="Guardar" />
                                </StackPanel>
                            </Button>
                            <Button Content="Cancelar" Classes="Ghost"
                                    IsVisible="{Binding IsEditingSite}"
                                    Command="{Binding CancelSiteEditCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding SiteMessage}" FontSize="12"
                                   Foreground="{Binding SiteSaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding SiteMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ── Reglas de acceso ───────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Control de acceso" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                   Text="Reglas del molinete/kiosko: cuánto puede deber un socio antes de avisar o bloquear el ingreso, y el tiempo mínimo entre pasadas (anti-passback)." />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Avisar deuda desde" Classes="FormLabel" />
                                <NumericUpDown Value="{Binding WarnOnOweAmount}" Minimum="0" Increment="1000"
                                               FormatString="C0" Width="160" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Bloquear deuda desde" Classes="FormLabel" />
                                <NumericUpDown Value="{Binding StopOnOweAmount}" Minimum="0" Increment="1000"
                                               FormatString="C0" Width="160" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Anti-passback (min)" Classes="FormLabel" />
                                <NumericUpDown Value="{Binding AntiPassbackMinutes}" Minimum="0" Maximum="120"
                                               Increment="1" Width="130" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding AccessMessage}" FontSize="12"
                                   Foreground="{Binding AccessSaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding AccessMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                        <Button Content="Guardar reglas" Command="{Binding SaveAccessCommand}" Classes="Primary"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- ── Licencia ───────────────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Licencia" FontSize="15" FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding LicensePlanDisplay}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LicenseUsageDisplay}" Classes="FormLabel" />
                        </StackPanel>
                        <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                   Text="El plan Free permite 1 sede y 50 socios. Para ampliar los límites, pegá la clave de licencia que recibiste al comprar tu plan." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding LicenseKeyInput}" Watermark="GYMF.…" Width="430" />
                            <Button Content="Activar" Command="{Binding ActivateLicenseCommand}" Classes="Primary" />
                        </StackPanel>
                        <TextBlock Text="{Binding LicenseMessage}" FontSize="12"
                                   Foreground="{Binding LicenseSaved, Converter={StaticResource ActiveColorBrushConverter}}"
                                   IsVisible="{Binding LicenseMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ── Info del sistema ───────────────────────────────────── -->
                <Border Classes="Card" Padding="24">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Sistema" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock FontSize="12" Opacity="0.7"
                                   Text="Los datos se guardan localmente en esta PC (%LOCALAPPDATA%\GymForge). Moneda: ARS · Zona horaria: Argentina (UTC-3)."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
