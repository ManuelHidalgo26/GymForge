<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:GymForge.Desktop.ViewModels.Shared"
             x:Class="GymForge.Desktop.Views.Shared.PlaceholderView"
             x:DataType="vm:PlaceholderViewModel">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="16" HorizontalAlignment="Center">

            <Border Width="80" Height="80" CornerRadius="40"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    HorizontalAlignment="Center">
                <fa:SymbolIcon Symbol="{Binding Icon}"
                               FontSize="36" Opacity="0.4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>

            <TextBlock Text="{Binding Title}"
                       FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <TextBlock Text="{Binding Subtitle}"
                       FontSize="13" Opacity="0.55"
                       HorizontalAlignment="Center"
                       MaxWidth="320" TextWrapping="Wrap"
                       TextAlignment="Center" />

        </StackPanel>
    </Grid>

</UserControl>
