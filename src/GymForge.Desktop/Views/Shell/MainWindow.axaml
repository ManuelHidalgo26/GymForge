<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="using:FluentAvalonia.UI.Controls"
        xmlns:vm="using:GymForge.Desktop.Views.Shell"
        xmlns:svc="using:GymForge.Desktop.Services"
        xmlns:conv="using:GymForge.Desktop.Converters"
        mc:Ignorable="d"
        x:Class="GymForge.Desktop.Views.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding GymName}"
        Icon="/Assets/gymforge.ico"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:NavSectionActiveConverter x:Key="NavSectionActiveConverter" />
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="F1" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavSection.Dashboard}" />
        <KeyBinding Gesture="F3" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavSection.Members}" />
        <KeyBinding Gesture="F4" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavSection.Access}" />
        <KeyBinding Gesture="F5" Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavSection.Cash}" />
        <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenCommandPaletteCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
        <KeyBinding Gesture="Alt+Left" Command="{Binding GoBackCommand}" />
    </Window.KeyBindings>

    <Grid ColumnDefinitions="Auto,*">

        <!-- ═══ SIDEBAR ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Width="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarWidthConverter}}"
                Background="{DynamicResource SidebarBackground}"
                BoxShadow="2 0 8 0 #22000000">
            <DockPanel>

                <!-- Logo + Gym Name -->
                <Border DockPanel.Dock="Top" Padding="12,16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource SystemAccentColor}">
                            <TextBlock Text="GF" FontWeight="Bold" FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel IsVisible="{Binding !IsSidebarCollapsed}">
                            <TextBlock Text="{Binding GymName}" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding CurrentSiteName}" FontSize="11" Opacity="0.6" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="2" Margin="8,0">

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Dashboard}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Dashboard}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Home}" FontSize="18" />
                                <TextBlock Text="Dashboard" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Members}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Members}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.People}" FontSize="18" />
                                <TextBlock Text="Socios" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Access}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Access}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Permissions}" FontSize="18" />
                                <TextBlock Text="Accesos" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Cash}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Cash}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="18" />
                                <TextBlock Text="Caja" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Plans}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Plans}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.List}" FontSize="18" />
                                <TextBlock Text="Planes" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Classes}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Classes}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Calendar}" FontSize="18" />
                                <TextBlock Text="Clases" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Routines}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Routines}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Globe}" FontSize="18" />
                                <TextBlock Text="Rutinas" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Products}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Products}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Tag}" FontSize="18" />
                                <TextBlock Text="Productos" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:NavSection.Reports}"
                                Classes="NavButton"
                                Classes.active="{Binding CurrentSection,
                                    Converter={StaticResource NavSectionActiveConverter},
                                    ConverterParameter=Reports}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Document}" FontSize="18" />
                                <TextBlock Text="Reportes" IsVisible="{Binding !IsSidebarCollapsed}" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Settings + theme toggle + collapse -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,8" Spacing="2">

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static vm:NavSection.Settings}"
                            Classes="NavButton"
                            Classes.active="{Binding CurrentSection,
                                Converter={StaticResource NavSectionActiveConverter},
                                ConverterParameter=Settings}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Settings}" FontSize="18" />
                            <TextBlock Text="Configuración" IsVisible="{Binding !IsSidebarCollapsed}" />
                        </StackPanel>
                    </Button>

                    <!-- Theme toggle (only visible when expanded) -->
                    <Button Command="{Binding ToggleThemeCommand}"
                            Classes="NavButton"
                            IsVisible="{Binding !IsSidebarCollapsed}"
                            ToolTip.Tip="Cambiar tema claro/oscuro">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.DarkTheme}" FontSize="18" />
                            <TextBlock Text="Cambiar tema"
                                       IsVisible="{Binding !IsSidebarCollapsed}" />
                        </StackPanel>
                    </Button>

                    <!-- Collapse toggle -->
                    <Button Command="{Binding ToggleSidebarCommand}" Classes="NavButton">
                        <fa:SymbolIcon FontSize="18"
                            Symbol="{Binding IsSidebarCollapsed,
                                Converter={StaticResource CollapsedIconConverter}}" />
                    </Button>

                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" RowDefinitions="48,*">

            <!-- Topbar -->
            <Border Grid.Row="0" Padding="16,0"
                    Background="{DynamicResource TopbarBackground}"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Back button (visible when navigated to a detail view) -->
                    <Button DockPanel.Dock="Left"
                            Command="{Binding GoBackCommand}"
                            IsVisible="{Binding CanGoBack}"
                            Classes="NavButton"
                            Margin="0,0,4,0"
                            ToolTip.Tip="Volver (Alt+←)">
                        <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Back}" FontSize="18" />
                    </Button>

                    <!-- Global search Ctrl+K -->
                    <Button DockPanel.Dock="Left"
                            Command="{Binding OpenCommandPaletteCommand}"
                            Classes="SearchButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Find}" FontSize="16" Opacity="0.5" />
                            <TextBlock Text="Buscar... (Ctrl+K)" Opacity="0.5" FontSize="13" />
                        </StackPanel>
                    </Button>

                    <!-- Site selector -->
                    <ComboBox DockPanel.Dock="Left" Margin="12,0,0,0" MinWidth="170"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Session.Sites}"
                              SelectedItem="{Binding Session.CurrentSite}"
                              ToolTip.Tip="Sede activa">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="svc:SiteOption">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <fa:SymbolIcon Symbol="{x:Static fa:Symbol.Home}" FontSize="14" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Right side: cashier + staff avatar -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Session.CashierName}"
                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                   IsVisible="{Binding Session.IsSignedIn}" />
                        <Border Width="32" Height="32" CornerRadius="16"
                                Background="{DynamicResource SystemAccentColor}"
                                ToolTip.Tip="{Binding Session.CashierName}">
                            <TextBlock Text="A" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content router — DataTemplates in App.axaml resolve the correct View -->
            <ContentControl Grid.Row="1"
                            Name="ContentArea"
                            Content="{Binding CurrentViewModel}" />

        </Grid>

    </Grid>
</Window>
